# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/cricsauction
# For production, use: mysql+aiomysql://user:password@host:3306/dbname

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=CricAuction

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Payment Gateway Configuration
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
STRIPE_API_KEY=your-stripe-key
STRIPE_SECRET_KEY=your-stripe-secret
CASHFREE_API_KEY=your-cashfree-key

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1

# MinIO Configuration (Alternative to S3)
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Application Configuration
APP_NAME=CricAuction
APP_VERSION=1.0.0
